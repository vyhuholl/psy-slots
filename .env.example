# Telegram
BOT_TOKEN=
WEBHOOK_SECRET=
ADMIN_TELEGRAM_ID=

# YDB
YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
YDB_DATABASE=/ru-central1/<cloud>/<db-id>
YDB_SERVICE_ACCOUNT_KEY_FILE_CREDENTIALS=~/Documents/psy-slots/key.json

# Психолог (единственный) — параметры из окружения.
# Таймзона не настраивается: всегда Europe/Moscow.
SLOT_DURATION_MINUTES=20
AVAILABILITY_INTERVALS=14:00-15:00

# Тексты
WELCOME_MESSAGE="Вас приветствует личный бот психолога. Чтобы записаться на тестовую сессию, выберите один из слотов ниже."
BOOKING_UNAVAILABLE_MESSAGE="Вас приветствует личный бот психолога. К сожалению, на сегодня все слоты закончились."
